# データモード: mock | supabase （未設定時は mock）
DATA_MODE=mock

# --- Supabase（DATA_MODE=supabase のときのみ必要。フェーズ3で実装） ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cloudflare R2（3Dモデル置き場。フェーズ3で実装） ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=zaimoku-models
R2_PUBLIC_BASE_URL=https://models.example.com

# --- Resend（メール通知。フェーズ2以降でスタブ→本実装） ---
RESEND_API_KEY=your-resend-api-key
