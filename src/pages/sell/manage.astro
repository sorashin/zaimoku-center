---
import Base from '@/layouts/Base.astro';
import { getSession } from '@/lib/server/session';
import { getData } from '@/lib/server/data';
import { ManageList, type ManageItem } from '@/components/sell/ManageList';
import { formatPrice, priceUnitLabel } from '@/lib/format';

export const prerender = false;

const data = getData(Astro.locals.runtime?.env);
const session = await getSession(Astro);
const user = session.user;
const sellerId = user?.sellerProfile?.sellerId;

let items: ManageItem[] = [];
if (user?.role === 'seller' && sellerId) {
  const listings = await data.getSellerListings(sellerId, true);
  items = listings.map((l) => {
    const main = l.photos.find((p) => p.isMain) ?? l.photos[0];
    return {
      id: l.id,
      title: l.title,
      species: l.species,
      isSawn: l.shape === 'sawn',
      priceLabel: formatPrice(l.price),
      unitLabel: priceUnitLabel(l.priceUnit),
      stockLine: l.shape === 'sawn' ? `在庫 ${l.stock} 本` : '一点物',
      status: l.status,
      thumb: main?.url ?? '',
    };
  });
}
---

<Base title="出品管理">
  <div class="mx-auto max-w-[640px] px-4 py-8 md:px-6">
    {
      user?.role === 'seller' && sellerId ? (
        <>
          <div class="flex items-center justify-between">
            <h1 class="text-[21px] font-semibold">出品管理</h1>
            <a
              href="/sell"
              class="inline-flex h-10 items-center gap-1.5 rounded-pill bg-primary px-4 text-[14px] font-bold text-ink no-underline transition-colors hover:bg-primary-active"
            >
              ＋ 新規出品
            </a>
          </div>
          <p class="mb-5 mt-1.5 text-[13px] text-ink-sub">{user.name}の出品一覧</p>
          <ManageList items={items} client:load />
        </>
      ) : !user ? (
        <p class="mt-3 text-[14px] text-ink-sub">
          出品管理にはログインが必要です。
          <a href="/login?redirect=/sell/manage" class="font-semibold text-ink underline">
            ログイン
          </a>
          してください。
        </p>
      ) : (
        <p class="mt-3 text-[14px] text-ink-sub">
          出品管理は出品者アカウントのみ利用できます。
        </p>
      )
    }
  </div>
</Base>
