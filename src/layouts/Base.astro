---
import '@/styles/global.css';
import { getSession } from '@/lib/server/session';

interface Props {
  title?: string;
  description?: string;
  /** ヘッダーを表示するか（既定 true） */
  header?: boolean;
}

const { title, description, header = true } = Astro.props;
const session = await getSession(Astro);
const user = session.user;

const fullTitle = title ? `${title}｜伊那材木センター` : '伊那材木センター';
const desc =
  description ??
  '地域材・不採算木材を3Dスキャンで「一本ずつの価値」として可視化する、伊那谷の材木マーケットプレイス。';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      header && (
        <header class="sticky top-0 z-30 border-b border-hairline bg-surface/95 backdrop-blur">
          <div class="mx-auto flex max-w-[1440px] items-center gap-3 px-4 py-3 md:px-6">
            <a href="/" class="flex items-center gap-2.5 no-underline">
              {/* 丸太ロゴ（同心円・暖色） */}
              <svg width="30" height="30" viewBox="0 0 30 30" aria-hidden="true">
                <circle cx="15" cy="15" r="13" fill="#FF9F1C" />
                <circle cx="15" cy="15" r="9" fill="none" stroke="#F18B00" stroke-width="1.6" />
                <circle cx="15" cy="15" r="5" fill="none" stroke="#C76A00" stroke-width="1.4" />
                <circle cx="15" cy="15" r="1.8" fill="#8a4f00" />
              </svg>
              <span class="text-[18px] font-bold tracking-[0.01em] text-ink">
                伊那材木センター
              </span>
            </a>

            <div class="ml-auto flex items-center gap-2.5">
              <a
                href="/sell"
                class="flex items-center gap-1.5 rounded-pill border border-ink bg-surface px-3.5 py-2 text-[13px] font-semibold text-ink no-underline transition-colors hover:bg-surface-muted"
              >
                出品する
              </a>

              {user ? (
                <div class="flex items-center gap-2">
                  <a
                    href="/favorites"
                    aria-label="お気に入り"
                    class="hidden h-9 w-9 items-center justify-center rounded-pill border border-hairline bg-surface text-ink no-underline hover:bg-surface-muted sm:flex"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                      <path
                        d="M12 21C12 21 3.5 15.5 3.5 9.5C3.5 6.5 5.8 4.5 8.3 4.5C10 4.5 11.4 5.5 12 6.6C12.6 5.5 14 4.5 15.7 4.5C18.2 4.5 20.5 6.5 20.5 9.5C20.5 15.5 12 21 12 21Z"
                        fill="none"
                        stroke="#222222"
                        stroke-width="1.8"
                      />
                    </svg>
                  </a>
                  <span class="hidden text-[13px] font-medium text-ink-sub sm:inline">
                    {user.name}
                  </span>
                  <form method="POST" action="/api/auth/signout">
                    <button
                      type="submit"
                      class="rounded-pill border border-hairline bg-surface px-3 py-2 text-[13px] font-medium text-ink-sub hover:bg-surface-muted"
                    >
                      ログアウト
                    </button>
                  </form>
                </div>
              ) : (
                <a
                  href="/login"
                  class="rounded-pill bg-primary px-4 py-2 text-[13px] font-bold text-ink no-underline transition-colors hover:bg-primary-active"
                >
                  ログイン
                </a>
              )}
            </div>
          </div>
        </header>
      )
    }

    <main>
      <slot />
    </main>
  </body>
</html>
