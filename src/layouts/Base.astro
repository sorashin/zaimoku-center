---
import '@/styles/global.css';
import { getSession } from '@/lib/server/session';
import UserAvatar from '@/components/UserAvatar.astro';

interface Props {
  title?: string;
  description?: string;
  /** ヘッダーを表示するか（既定 true） */
  header?: boolean;
}

const { title, description, header = true } = Astro.props;
const session = await getSession(Astro);
const user = session.user;

const fullTitle = title ? `${title}｜伊那材木センター` : '伊那材木センター';
const desc =
  description ??
  '地域材・不採算木材を3Dスキャンで「一本ずつの価値」として可視化する、伊那谷の材木マーケットプレイス。';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      header && (
        <header class="sticky top-0 z-30 border-b border-hairline bg-surface/95 backdrop-blur">
          <div class="mx-auto flex max-w-[1440px] items-center gap-3 px-4 py-2.5 md:px-6">
            <a href="/" class="flex items-center gap-2.5 no-underline">
              {/* 丸太ロゴ（同心円・暖色） */}
              <svg width="28" height="28" viewBox="0 0 30 30" aria-hidden="true">
                <circle cx="15" cy="15" r="13" fill="#FF9F1C" />
                <circle cx="15" cy="15" r="9" fill="none" stroke="#F18B00" stroke-width="1.6" />
                <circle cx="15" cy="15" r="5" fill="none" stroke="#C76A00" stroke-width="1.4" />
                <circle cx="15" cy="15" r="1.8" fill="#8a4f00" />
              </svg>
              <span class="text-[17px] font-bold tracking-[0.01em] text-ink">
                伊那材木センター
              </span>
            </a>

            <div class="ml-auto flex items-center gap-2">
              {user ? (
                <div class="relative" data-menu>
                  {/* アバター（メニュートグル） */}
                  <button
                    type="button"
                    data-menu-toggle
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-label="メニュー"
                    class="flex items-center rounded-pill border-none bg-transparent p-0 transition-opacity hover:opacity-80"
                  >
                    <UserAvatar name={user.name} seed={user.id} url={user.avatarUrl} />
                  </button>

                  {/* ドロップダウンメニュー */}
                  <div
                    data-menu-panel
                    hidden
                    class="absolute right-0 top-[calc(100%_+_8px)] z-40 w-52 overflow-hidden rounded-card border border-hairline bg-surface py-1.5 shadow-[rgba(0,0,0,0.12)_0_8px_24px_0]"
                  >
                    <div class="border-b border-hairline px-4 pb-2 pt-1">
                      <div class="truncate text-[14px] font-semibold text-ink">{user.name}</div>
                    </div>
                    <a href="/sell" class="flex items-center gap-2.5 px-4 py-2.5 text-[14px] font-medium text-ink no-underline hover:bg-surface-muted">
                      <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                        <path d="M9 3.5v11M3.5 9h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                      </svg>
                      出品する
                    </a>
                    {user.role === 'seller' && (
                      <a href="/sell/manage" class="flex items-center gap-2.5 px-4 py-2.5 text-[14px] font-medium text-ink no-underline hover:bg-surface-muted">
                        <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                          <rect x="2.5" y="2.5" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.6" />
                          <rect x="10" y="2.5" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.6" />
                          <rect x="2.5" y="10" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.6" />
                          <rect x="10" y="10" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.6" />
                        </svg>
                        出品管理
                      </a>
                    )}
                    <a href="/favorites" class="flex items-center gap-2.5 px-4 py-2.5 text-[14px] font-medium text-ink no-underline hover:bg-surface-muted">
                      <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
                        <path
                          d="M12 21C12 21 3.5 15.5 3.5 9.5C3.5 6.5 5.8 4.5 8.3 4.5C10 4.5 11.4 5.5 12 6.6C12.6 5.5 14 4.5 15.7 4.5C18.2 4.5 20.5 6.5 20.5 9.5C20.5 15.5 12 21 12 21Z"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.8"
                        />
                      </svg>
                      お気に入り
                    </a>
                    <form method="POST" action="/api/auth/signout" class="border-t border-hairline">
                      <button
                        type="submit"
                        class="flex w-full items-center gap-2.5 px-4 py-2.5 text-left text-[14px] font-medium text-ink-sub hover:bg-surface-muted"
                      >
                        <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                          <path d="M7 2.5H4a1.5 1.5 0 00-1.5 1.5v10A1.5 1.5 0 004 15.5h3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                          <path d="M11 12.5L14.5 9 11 5.5M14 9H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        ログアウト
                      </button>
                    </form>
                  </div>
                </div>
              ) : (
                <>
                  <a
                    href="/sell"
                    class="flex items-center gap-1.5 rounded-pill border border-ink bg-surface px-3.5 py-2 text-[13px] font-semibold text-ink no-underline transition-colors hover:bg-surface-muted"
                  >
                    出品する
                  </a>
                  <a
                    href="/login"
                    class="rounded-pill bg-primary px-4 py-2 text-[13px] font-bold text-ink no-underline transition-colors hover:bg-primary-active"
                  >
                    ログイン
                  </a>
                </>
              )}
            </div>
          </div>
        </header>

      )
    }

    {/* ヘッダーメニューの開閉（クリック外で閉じる / Escで閉じる） */}
    <script is:inline>
      const root = document.querySelector('[data-menu]');
      if (root) {
        const toggle = root.querySelector('[data-menu-toggle]');
        const panel = root.querySelector('[data-menu-panel]');
        if (toggle && panel) {
          const open = () => {
            panel.hidden = false;
            toggle.setAttribute('aria-expanded', 'true');
          };
          const close = () => {
            panel.hidden = true;
            toggle.setAttribute('aria-expanded', 'false');
          };
          toggle.addEventListener('click', (e) => {
            e.stopPropagation();
            panel.hidden ? open() : close();
          });
          document.addEventListener('click', (e) => {
            if (!root.contains(e.target)) close();
          });
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') close();
          });
        }
      }
    </script>

    <main>
      <slot />
    </main>
  </body>
</html>
